rules_version = '2';
// =============================================================================
// Ay Bay Er GustiMari — Firebase Storage Security Rules
// =============================================================================
// DEPLOY: Firebase Console → Storage → Rules → paste this content → Publish
// =============================================================================
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'chotan4480@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Blog cover images — admin can write; any authenticated user can read
    match /blog_images/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024   // max 5 MB
        && request.resource.contentType.matches('image/.*');
    }

    // User profile photos — owner can write; admin and owner can read
    match /profile_photos/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
